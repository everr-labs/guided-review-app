APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
APPLE_SIGNING_IDENTITY=

# Optional GitHub release settings used by npm run release:local.
# Defaults:
# RELEASE_TAG=guided-review-v<package.json version>
# RELEASE_NAME=Guided Review v<package.json version>
# RELEASE_NOTES=Signed and notarized macOS build. Download the app from the assets below.
# RELEASE_DRAFT=false
# RELEASE_PRERELEASE=false
#
# Set GH_REPO when your local remote points at an old or forked repo.
# GH_REPO=everr-labs/guided-review-app

# For local builds, use the Developer ID Application identity installed in Keychain.
# Find it with:
# security find-identity -v -p codesigning
#
# Example:
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)
#
# For CI-style local testing instead, leave APPLE_SIGNING_IDENTITY empty and set:
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
